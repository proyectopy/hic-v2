<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>HIC Dashboard</title>

    <style>
        body {
            font-family: Arial;
            background: #111;
            color: #fff;
            text-align: center;
        }

        .box {
            margin: 20px;
            padding: 20px;
            border: 1px solid #333;
            display: inline-block;
            width: 200px;
        }

        .value {
            font-size: 40px;
        }

        .label {
            font-size: 18px;
            opacity: 0.7;
        }

        .state {
            font-size: 14px;
            margin-top: 5px;
            opacity: 0.8;
        }
    </style>
</head>

<body>

<h1>HIC Live Dashboard</h1>

<div class="box">
    <div class="label">CPU</div>
    <div id="cpu" class="value">--</div>
    <div id="cpuState" class="state">--</div>
</div>

<div class="box">
    <div class="label">RAM</div>
    <div id="ram" class="value">--</div>
    <div id="ramState" class="state">--</div>
</div>

<script>
const ws = new WebSocket(`ws://${location.host}`);

ws.onmessage = (msg) => {
    const data = JSON.parse(msg.data);

    console.log("WS RAW:", data);

    let cpu = null;
    let ram = null;

    if (typeof data.cpu === "number") cpu = data.cpu;
    if (typeof data.ram === "number") ram = data.ram;

    if (data.state) {
        if (typeof data.state.cpu === "string") {
            document.getElementById("cpuState").innerText =
                data.state.cpu.toUpperCase();
        }

        if (typeof data.state.ram === "string") {
            document.getElementById("ramState").innerText =
                data.state.ram.toUpperCase();
        }
    }

    document.getElementById("cpu").innerText =
        cpu !== null ? cpu + "%" : "--";

    document.getElementById("ram").innerText =
        ram !== null ? ram + "%" : "--";
};
</script>

</body>
</html>